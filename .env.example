# -----------------------------------------------------------------------------
# How to use
# -----------------------------------------------------------------------------
# This repo does not auto-load .env in pipeline_2026. Export variables in your
# shell, or: set -a && source .env && set +a
#
# Stage 2 (HF activations + SAELens): Hugging Face token is the main secret.
# Legacy pipeline/ configs may use Mistral or other providers (see repo README).

# --- Hugging Face Hub (Stage 2: transformers + SAELens checkpoint download) ---
# Use for gated models, higher rate limits, and private checkpoints.
# huggingface_hub accepts either name.
HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=

# --- Optional cluster / runtime (not secrets; often set in Slurm, not in .env) ---
# CUDA_VISIBLE_DEVICES=0

# --- Google APIs (optional; e.g. AI Studio / other Google Cloud GenAI) ---
GOOGLE_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_STUDIO_MODEL=

# --- Mistral (legacy pipeline; config/llm.py and related scripts) ---
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral/mistral-small-latest

# --- Other LLM providers (only if you point config at them) ---
OPENAI_API_KEY=
TOGETHER_API_KEY=
