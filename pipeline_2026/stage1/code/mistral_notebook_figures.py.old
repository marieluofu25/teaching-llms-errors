#!/usr/bin/env python3
"""Mistral notebook-aligned MMLU figures for Stage 1 comparison."""
from __future__ import annotations

import argparse
import csv
import json
import math
import os
import sys
from pathlib import Path


def _prepare_legacy_pipeline_cwd() -> Path:
    """Configure cwd/sys.path so legacy ``pipeline/`` imports resolve correctly."""
    here = Path(__file__).resolve()
    pipeline_2026 = here.parents[2]
    repo = pipeline_2026.parent
    pl = repo / "pipeline"
    if not pl.is_dir():
        raise FileNotFoundError(f"expected legacy pipeline at {pl}")
    st = pl / "stage1_do_errors_exist"
    for p in (str(st), str(pl)):
        if p not in sys.path:
            sys.path.insert(0, p)
    os.chdir(pl)
    return pl


_prepare_legacy_pipeline_cwd()

import matplotlib  # noqa: E402

matplotlib.use("Agg")

import matplotlib.cm as cm  # noqa: E402
import matplotlib.colors as mcolors  # noqa: E402
import matplotlib.pyplot as plt  # noqa: E402
import numpy as np  # noqa: E402
import pandas as pd  # noqa: E402
from utils import calculate_error_metrics, df_to_dict  # noqa: E402

MMLU_PICKLE = Path("stage1_do_errors_exist/datasets/mmlu_df_gpt35.pkl")


def _coerce_bool(v: object) -> bool | None:
    """Parse loose truthy/falsey values from CSV cells."""
    if isinstance(v, bool):
        return v
    s = str(v).strip().lower()
    if s in {"true", "t", "1", "yes", "y"}:
        return True
    if s in {"false", "f", "0", "no", "n"}:
        return False
    return None


def _cmap_oranges():
    """Return an Oranges colormap compatible with old/new matplotlib APIs."""
    reg = getattr(matplotlib, "colormaps", None)
    if reg is not None:
        return reg["Oranges"]
    return cm.get_cmap("Oranges")


def _plot_metrics_orange(data: dict) -> None:
    """Draw single-panel horizontal metric bars with coverage color scale."""
    sorted_items = sorted(data.items(), key=lambda x: x[1]["wrongVScorrect"])
    properties = [item[0] for item in sorted_items]
    wrong_vs_correct = np.array([data[p]["wrongVScorrect"] for p in properties])
    coverage = np.array([data[p]["coverage"] for p in properties])
    norm = mcolors.Normalize(vmin=min(coverage), vmax=max(coverage))
    cmap = _cmap_oranges()
    colors = cmap(norm(coverage))
    fig, ax = plt.subplots(figsize=(8, len(properties) * 0.5))
    ax.barh(properties, wrong_vs_correct, color=colors, edgecolor="black")
    sm = cm.ScalarMappable(cmap=cmap, norm=norm)
    sm.set_array([])
    cbar = plt.colorbar(sm, ax=ax)
    cbar.set_label("Coverage")
    ax.set_xlabel("Wrong / Correct")
    ax.set_ylabel("Property")
    ax.set_title("Error Ratio and Coverage per Meta-Label")


def _plot_metrics_fig_orange(
    data: dict,
    ax,
    title: str,
    norm: mcolors.Normalize,
    cmap,
    xlim: tuple[float, float],
    max_items: int = 10,
    fsize: int = 12,
) -> None:
    """Draw one subplot with top items and orange coverage shading."""
    sorted_items = sorted(data.items(), key=lambda x: x[1]["wrongVScorrect"])
    selected_items = sorted_items[-max_items:]
    properties = [item[0] for item in selected_items]
    wrong_vs_correct = np.array([item[1]["wrongVScorrect"] for item in selected_items])
    coverage = np.array([item[1]["coverage"] for item in selected_items])
    colors = cmap(norm(coverage))
    ax.barh(properties, wrong_vs_correct, color=colors, edgecolor="black")
    ax.axvline(x=0.5, color="red", linestyle="dashed", linewidth=2)
    ax.set_xlabel("Error Ratio")
    ax.set_title(title, fontsize=fsize + 2)
    ax.set_xlim(xlim)
    ax.tick_params(axis="y", labelsize=fsize)
    ax.tick_params(axis="x", labelsize=fsize - 1)


def _save_plot_metrics(qm: dict, out: Path, filename: str, written: list[str], skipped: list[dict]) -> None:
    """Render+save metric bars while tracking skipped figures."""
    try:
        _plot_metrics_orange(qm)
        fig = plt.gcf()
        fig.savefig(out / filename, dpi=300, bbox_inches="tight", pad_inches=0.05)
        plt.close(fig)
        written.append(filename)
    except Exception as e:  # noqa: BLE001
        plt.close("all")
        skipped.append({"figure": filename, "error": str(e)})


def _save_figure(fig, out: Path, filename: str, written: list[str], skipped: list[dict]) -> None:
    """Persist figure output and close handles in all cases."""
    try:
        fig.savefig(out / filename, dpi=300, bbox_inches="tight", pad_inches=0.05)
        written.append(filename)
    except Exception as e:  # noqa: BLE001
        skipped.append({"figure": filename, "error": str(e)})
    finally:
        plt.close(fig)


def _load_subject_map() -> pd.DataFrame:
    """Load subject/subcat/cat map from the canonical MMLU pickle."""
    if not MMLU_PICKLE.is_file():
        raise FileNotFoundError(str(MMLU_PICKLE.resolve()))
    df = pd.read_pickle(MMLU_PICKLE)
    if "subject" not in df.columns and "metadata" in df.columns:
        df["subject"] = df["metadata"].apply(lambda x: x[0])
    if "subcat" not in df.columns and "metadata" in df.columns:
        df["subcat"] = df["metadata"].apply(lambda x: x[1])
    if "cat" not in df.columns and "metadata" in df.columns:
        df["cat"] = df["metadata"].apply(lambda x: x[2])
    return df[["subject", "subcat", "cat"]].dropna().drop_duplicates("subject")


def _paper_subcat_order() -> list[str]:
    """Subcat order aligned with legacy paper plot (order of first appearance)."""
    if not MMLU_PICKLE.is_file():
        return []
    df = pd.read_pickle(MMLU_PICKLE)
    if "subcat" not in df.columns and "metadata" in df.columns:
        df["subcat"] = df["metadata"].apply(lambda x: x[1])
    seen: set[str] = set()
    out: list[str] = []
    for s in df["subcat"].dropna().tolist():
        s = str(s)
        if s in {"math", "health"}:
            continue
        if s not in seen:
            seen.add(s)
            out.append(s)
    return out


def _load_mistral_df(csv_path: Path) -> tuple[pd.DataFrame, int, int]:
    """Read mistral predictions CSV and return normalized boolean rows."""
    rows: list[dict] = []
    in_rows = 0
    with open(csv_path, newline="", encoding="utf-8") as f:
        r = csv.DictReader(f)
        for row in r:
            in_rows += 1
            subject = str(row.get("subject") or "").strip()
            ok = _coerce_bool(row.get("ai_correct"))
            if not subject or ok is None:
                continue
            rows.append({"subject": subject, "ai_correct": bool(ok)})
    df = pd.DataFrame(rows)
    return df, in_rows, len(rows)


def main() -> None:
    """Generate Mistral notebook-style MMLU comparison figures and summary."""
    p = argparse.ArgumentParser()
    p.add_argument("--mistral-csv", type=Path, required=True)
    p.add_argument("--output-dir", type=Path, required=True)
    args = p.parse_args()

    out = args.output_dir.resolve()
    out.mkdir(parents=True, exist_ok=True)
    csv_path = args.mistral_csv.resolve()

    written: list[str] = []
    skipped: list[dict] = []
    summary: dict = {"figures_written": written, "figures_skipped": skipped, "source_table": str(csv_path)}

    mdf, n_input, n_valid = _load_mistral_df(csv_path)
    if n_valid == 0:
        summary["error"] = "no_valid_rows"
        summary["n_input_rows"] = n_input
        (out / "mistral_notebook_summary.json").write_text(json.dumps(summary, indent=2), encoding="utf-8")
        print("mistral_notebook_figures: no valid rows", file=sys.stderr)
        return

    try:
        smap = _load_subject_map()
    except Exception as e:  # noqa: BLE001
        summary["error"] = f"subject_map_failed: {e}"
        (out / "mistral_notebook_summary.json").write_text(json.dumps(summary, indent=2), encoding="utf-8")
        print(f"mistral_notebook_figures: {e}", file=sys.stderr)
        return

    mmlu = mdf.merge(smap, on="subject", how="left")
    dropped_unmapped = int(mmlu["subcat"].isna().sum())
    mmlu = mmlu.dropna(subset=["subcat", "cat"]).copy()
    mmlu["ai_model"] = "mistral-mmlu"
    mmlu["ai_correct"] = mmlu["ai_correct"].astype(bool)

    # 03: MMLU math-reg by subject
    d = mmlu[mmlu["subcat"] == "math"]
    df = calculate_error_metrics(d, "subject", "ai_correct", mmlu=True)
    _save_plot_metrics(df_to_dict(df, "subject"), out, "mistral_nb_cell03_mmlu_math_reg.png", written, skipped)

    # 05: MMLU health-reg by subject
    d = mmlu[mmlu["subcat"] == "health"]
    df = calculate_error_metrics(d, "subject", "ai_correct", mmlu=True)
    _save_plot_metrics(df_to_dict(df, "subject"), out, "mistral_nb_cell05_mmlu_health_reg.png", written, skipped)

    # 07: subcat computer science
    d = mmlu[mmlu["subcat"] == "computer science"]
    df = calculate_error_metrics(d, "subject", "ai_correct", mmlu=True)
    _save_plot_metrics(
        df_to_dict(df, "subject"),
        out,
        "mistral_nb_cell07_mmlu_subcat_computer_science.png",
        written,
        skipped,
    )

    # 09: full MMLU by subject
    df = calculate_error_metrics(mmlu, "subject", "ai_correct", mmlu=True)
    _save_plot_metrics(df_to_dict(df, "subject"), out, "mistral_nb_cell09_mmlu_all_subjects.png", written, skipped)

    # 11: full MMLU by subcat
    df = calculate_error_metrics(mmlu, "subcat", "ai_correct", mmlu=True)
    _save_plot_metrics(df_to_dict(df, "subcat"), out, "mistral_nb_cell11_mmlu_by_subcat.png", written, skipped)

    # 13: psychology / physics / math subjects
    d = mmlu[mmlu["subcat"].isin(["psychology", "physics", "math"])]
    df = calculate_error_metrics(d, "subject", "ai_correct", mmlu=True)
    _save_plot_metrics(
        df_to_dict(df, "subject"),
        out,
        "mistral_nb_cell13_mmlu_subcats_psych_physics_math.png",
        written,
        skipped,
    )

    # 16 and 18: math+health variants
    try:
        m_math = mmlu[mmlu["subcat"] == "math"]
        m_health = mmlu[mmlu["subcat"] == "health"]
        df1 = calculate_error_metrics(m_math, "subject", "ai_correct", mmlu=True)
        df2 = calculate_error_metrics(m_health, "subject", "ai_correct", mmlu=True)
        qm1 = df_to_dict(df1, "subject")
        qm2 = df_to_dict(df2, "subject")
        fig_data = [qm1, qm2]
        names = ["MMLU-Math", "MMLU-Health"]
        all_cov = np.concatenate([np.array([x["coverage"] for x in q.values()]) for q in fig_data])
        all_ratio = np.concatenate([np.array([x["wrongVScorrect"] for x in q.values()]) for q in fig_data])
        norm = mcolors.Normalize(vmin=min(all_cov), vmax=max(all_cov))
        cmap = _cmap_oranges()
        xlim = (0, max(all_ratio) * 1.1 if len(all_ratio) else 1.0)

        fig, axes = plt.subplots(2, 1, figsize=(5, 10), constrained_layout=False)
        for ax, data, title in zip(axes, fig_data, names):
            _plot_metrics_fig_orange(data, ax, title, norm, cmap, xlim)
        fig.text(0.04, 0.5, "Subjects", ha="center", va="center", rotation="vertical", fontsize=14)
        plt.subplots_adjust(left=0.1, right=0.9, hspace=0.3)
        fig.canvas.draw()
        b0, b1 = axes[0].get_position(), axes[1].get_position()
        cax = fig.add_axes([b0.x1 + 0.02, b1.y0, 0.02, b0.y1 - b1.y0])
        cbar = fig.colorbar(cm.ScalarMappable(cmap=cmap, norm=norm), cax=cax, orientation="vertical")
        cbar.set_label("Coverage", fontsize=12, labelpad=20)
        _save_figure(fig, out, "mistral_nb_cell16_mmlu_math_health_vertical.png", written, skipped)

        fig, axes = plt.subplots(1, 2, figsize=(15, 5), constrained_layout=True)
        axes[0].set_ylabel("MMLU Subjects", fontsize=14)
        plt.subplots_adjust(left=0.05)
        for ax, data, title in zip(axes, fig_data, names):
            _plot_metrics_fig_orange(data, ax, title, norm, cmap, xlim)
        cbar = fig.colorbar(cm.ScalarMappable(cmap=cmap, norm=norm), ax=axes, orientation="vertical", fraction=0.02, pad=0.04)
        cbar.set_label("Coverage", fontsize=12, labelpad=20)
        _save_figure(fig, out, "mistral_nb_cell18_mmlu_math_health_horizontal.png", written, skipped)
    except Exception as e:  # noqa: BLE001
        skipped.append({"figure": "mistral_nb_cell16/18", "error": str(e)})
        plt.close("all")

    # 19: subcat grid excluding math & health
    try:
        paper_order = _paper_subcat_order()
        available = set(str(s) for s in mmlu["subcat"].dropna().unique())
        subcats = [s for s in paper_order if s in available]
        # Keep any extra subcats (if present) after the paper-aligned order.
        extras = [s for s in sorted(available) if s not in set(subcats) and s not in {"math", "health"}]
        subcats.extend(extras)
        qms = []
        for s in subcats:
            d = mmlu[mmlu["subcat"] == s]
            df = calculate_error_metrics(d, "subject", "ai_correct", mmlu=True)
            qms.append(df_to_dict(df, "subject"))
        plot_names = [f"MMLU-{s}" for s in subcats]
        ncols = 3
        nrows = math.ceil(len(qms) / ncols) if qms else 1
        fig, axes = plt.subplots(nrows, ncols, figsize=(15, 4 * nrows), constrained_layout=False)
        axes = np.ravel(axes)
        all_cov = np.concatenate([np.array([x["coverage"] for x in q.values()]) for q in qms]) if qms else np.array([0.0, 1.0])
        all_ratio = (
            np.concatenate([np.array([x["wrongVScorrect"] for x in q.values()]) for q in qms]) if qms else np.array([1.0])
        )
        norm = mcolors.Normalize(vmin=float(np.min(all_cov)), vmax=float(np.max(all_cov)))
        cmap = _cmap_oranges()
        xlim = (0, float(np.max(all_ratio)) * 1.1 if len(all_ratio) else 1.0)
        for ax, data, title in zip(axes, qms, plot_names):
            _plot_metrics_fig_orange(data, ax, title, norm, cmap, xlim)
        for ax in axes[len(qms) :]:
            ax.axis("off")
        fig.text(0, 0.5, "Subjects", ha="center", va="center", rotation="vertical", fontsize=14)
        plt.subplots_adjust(left=0.1, right=0.9, hspace=0.4, wspace=1.8)
        fig.canvas.draw()
        bboxes = [ax.get_position() for ax in axes if ax.get_visible()]
        bottom = min(b.y0 for b in bboxes)
        top = max(b.y1 for b in bboxes)
        left = max(b.x1 for b in bboxes) + 0.02
        cax = fig.add_axes([left, bottom, 0.02, top - bottom])
        cbar = fig.colorbar(cm.ScalarMappable(cmap=cmap, norm=norm), cax=cax, orientation="vertical")
        cbar.set_label("Coverage", fontsize=12, labelpad=20)
        _save_figure(fig, out, "mistral_nb_cell19_mmlu_subcats_grid.png", written, skipped)
    except Exception as e:  # noqa: BLE001
        skipped.append({"figure": "mistral_nb_cell19_mmlu_subcats_grid.png", "error": str(e)})
        plt.close("all")

    err_rate = float((~mmlu["ai_correct"]).mean())
    by_sub = (
        mmlu.groupby("subject", dropna=False)["ai_correct"]
        .apply(lambda s: float((~s).mean()))
        .sort_values(ascending=False)
        .head(30)
    )
    summary.update(
        {
            "n_input_rows": int(n_input),
            "n_rows": int(len(mmlu)),
            "n_dropped_rows": int(n_input - len(mmlu)),
            "n_unmapped_subject_rows": dropped_unmapped,
            "error_rate": round(err_rate, 6),
            "top_subjects_by_error_rate": [
                {"subject": str(k), "error_rate": round(float(v), 6)} for k, v in by_sub.items()
            ],
            "unavailable_paper_figures_for_mistral": [
                "paper_nb_cell24_mathcamps_gpt_claude_sonnet.png",
                "paper_nb_cell26_mathcamps_claude_family.png",
            ],
        }
    )
    (out / "mistral_notebook_summary.json").write_text(json.dumps(summary, indent=2), encoding="utf-8")
    print(f"Wrote {out / 'mistral_notebook_summary.json'}")
    for w in written:
        print(f"Wrote {out / w}")
    if skipped:
        print(f"mistral_notebook_figures: {len(skipped)} figure(s) skipped", file=sys.stderr)


if __name__ == "__main__":
    main()
