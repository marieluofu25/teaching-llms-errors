#!/usr/bin/env python3
"""Aggregate stability metrics from multiple metrics JSON files."""
from __future__ import annotations

import argparse
import json
from pathlib import Path

import numpy as np


def _read_overlap(path: Path) -> float | None:
    """Read ``set_level_metrics.stability.overlap_at_k_mean`` from a metrics JSON."""
    with open(path, "r", encoding="utf-8") as f:
        data = json.load(f)
    return (
        data.get("set_level_metrics", {})
        .get("stability", {})
        .get("overlap_at_k_mean")
    )


def main() -> None:
    """CLI entrypoint for stability aggregation."""
    parser = argparse.ArgumentParser(description="Aggregate overlap@k stability values")
    parser.add_argument(
        "--metrics-jsons",
        type=str,
        required=True,
        help="Comma-separated metrics JSON paths",
    )
    parser.add_argument("--output", type=Path, required=True)
    args = parser.parse_args()

    paths = [Path(p) for p in args.metrics_jsons.split(",") if p.strip()]
    values = [v for v in (_read_overlap(p) for p in paths if p.is_file()) if v is not None]
    out = {
        "n_files": len(paths),
        "n_values": len(values),
        "stability_overlap_at_k_mean": float(np.mean(values)) if values else None,
        "stability_overlap_at_k_std": float(np.std(values)) if values else None,
        "sources": [str(p) for p in paths],
    }
    args.output.parent.mkdir(parents=True, exist_ok=True)
    with open(args.output, "w", encoding="utf-8") as f:
        json.dump(out, f, indent=2)
    print(f"Wrote {args.output}")


if __name__ == "__main__":
    main()
